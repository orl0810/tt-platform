## 🚫 Anti-Patterns to Avoid

### ❌ Don't Duplicate Logic
```typescript
// ❌ BAD: Separate implementations
// apps/web/src/hooks/useSessions.ts
export function useSessions() { /* web-specific */ }

// apps/mobile/src/hooks/useSessions.ts
export function useSessions() { /* mobile-specific */ }

// ✅ GOOD: Single shared hook
// packages/shared/src/hooks/useSessions.ts
export function useSessions() { /* works everywhere */ }
```

### ❌ Don't Mix Concerns
```typescript
// ❌ BAD: Business logic in component
function SessionCard({ session }) {
  const [data, setData] = useState(null);
  
  useEffect(() => {
    // Firebase call directly in component
    getDoc(doc(db, "sessions", session.id)).then(setData);
  }, [session.id]);
  
  return <div>{data?.title}</div>;
}

// ✅ GOOD: Logic in hook/service
function SessionCard({ session }) {
  const { data } = useSessionDetails(session.id);
  return <div>{data?.title}</div>;
}
```

### ❌ Don't Ignore TypeScript Errors
```typescript
// ❌ BAD: Using 'any' or '@ts-ignore'
function processSession(session: any) {
  return session.title; // No type safety
}

// ✅ GOOD: Proper typing
function processSession(session: Session): string {
  return session.title;
}
```


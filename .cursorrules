## 🚀 Performance Optimization

### Code Splitting (Web)

```typescript
// ✅ GOOD: Lazy load routes
import { lazy, Suspense } from "react";

const SessionsPage = lazy(() => import("./routes/sessions/SessionsPage"));

function App() {
  return (
    <Suspense fallback={<Loader />}>
      <Routes>
        <Route path="/sessions" element={<SessionsPage />} />
      </Routes>
    </Suspense>
  );
}
```

### Memoization

```typescript
// ✅ GOOD: Memoize expensive computations
const filteredSessions = useMemo(
  () => sessions.filter((s) => s.level === selectedLevel),
  [sessions, selectedLevel]
);

// ✅ GOOD: Memoize callbacks passed to children
const handlePress = useCallback(
  (session: Session) => navigate(`/sessions/${session.id}`),
  [navigate]
);
```

### Image Optimization

**Web**:
```typescript
// Use modern formats with fallbacks
<picture>
  <source srcSet="image.avif" type="image/avif" />
  <source srcSet="image.webp" type="image/webp" />
  <img src="image.jpg" alt="..." loading="lazy" />
</picture>
```

**Mobile**:
```typescript
import { Image } from "expo-image";

// Use expo-image for caching and blurhash
<Image
  source={{ uri: session.thumbnailUrl }}
  placeholder={{ blurhash: session.blurhash }}
  contentFit="cover"
  transition={200}
/>
```


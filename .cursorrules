## 🔥 Firebase Integration Patterns

### Service Layer Pattern

**Always wrap Firebase calls in services**:

```typescript
// ✅ GOOD: Centralized service
export const authService = {
  async signIn(email: string, password: string) {
    const { user } = await signInWithEmailAndPassword(auth, email, password);
    return user;
  },
};

// Usage in component:
const handleLogin = async () => {
  await authService.signIn(email, password);
};
```

```typescript
// ❌ BAD: Direct Firebase calls in components
import { signInWithEmailAndPassword } from "firebase/auth";

const handleLogin = async () => {
  await signInWithEmailAndPassword(auth, email, password);
};
```

### Firestore Data Transformation

```typescript
// ✅ GOOD: Transform Firestore data to app types
const toSession = (doc: DocumentSnapshot): Session => ({
  id: doc.id,
  ...doc.data(),
  createdAt: doc.data()?.createdAt?.toDate() ?? new Date(),
});

export const sessionService = {
  async getAll(): Promise<Session[]> {
    const snap = await getDocs(collection(db, "sessions"));
    return snap.docs.map(toSession);
  },
};
```

### Real-time Listeners Pattern

```typescript
// ✅ GOOD: Cleanup listeners in useEffect
export function useFavorites(userId: string | undefined) {
  const [favorites, setFavorites] = useState<string[]>([]);

  useEffect(() => {
    if (!userId) return;

    const unsubscribe = onSnapshot(
      doc(db, "users", userId),
      (snap) => setFavorites(snap.data()?.favorites ?? [])
    );

    return unsubscribe; // Cleanup on unmount
  }, [userId]);

  return favorites;
}
```

